{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2021",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "types": ["node","jest","multer"],
    "ignoreDeprecations": "6.0",
    // Add this to help TS find files outside src if needed
    "esModuleInterop": true
  },
  "include": ["src/**/*", "generated/**/*"]
}
