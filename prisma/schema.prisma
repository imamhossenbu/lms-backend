generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- User Management ---
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  avatar        String?
  role          String    @default("STUDENT")
  status        String    @default("PENDING")
  verificationToken String?   @unique
  lastLoginAt       DateTime?
  
  bio           String?
  education     String?
  skills        String?
  interests     String?
  country       String?
  language      String?
  socialLinks   String?
  address       String?
  
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// --- Courses & Learning ---
model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  status      String
  courses     Course[]
}

model Course {
  id              String         @id @default(uuid())
  title           String
  slug            String         @unique
  description     String
  shortDescription String
  thumbnail       String?
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  instructorId    String
  level           String
  language        String
  price           Decimal
  isFree          Boolean        @default(false)
  status          String
  durationMinutes Int
  requirements    String?
  learningOutcomes String?
  tags            String?
  ratingAverage   Decimal        @default(0)
  totalStudents   Int            @default(0)

  orders          Order[]
  modules         CourseModule[]
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  description String?
  order       Int
  isLocked    Boolean  @default(true)
  createdAt   DateTime @default(now())
  durationMinutes Int      @default(0)

  lessons     Lesson[] 
}

model Lesson {
  id              String           @id @default(uuid())
  courseId        String
  moduleId        String
  module          CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  title           String
  type            String
  content         String?
  videoUrl        String?
  durationMinutes Int
  order           Int
  isPreview       Boolean          @default(false)
  resources       String?
  status          String
  lessonResources LessonResource[]
}
model LessonResource {
  id          String @id @default(uuid())
  lessonId    String
  lesson      Lesson @relation(fields: [lessonId], references: [id])
  title       String
  fileUrl     String
  fileType    String
  size        String
  isDownloadable Boolean @default(true)
}

model Enrollment {
  id                String    @id @default(uuid())
  userId            String
  courseId          String
  enrolledAt        DateTime  @default(now())
  status            String
  progressPercentage Int      @default(0)
  completedAt       DateTime?
}

// --- Assessments ---
model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  courseId       String
  lessonId       String
  isCompleted    Boolean   @default(false)
  watchedSeconds Int
  lastPosition   Int
  completedAt    DateTime?
}

model Quiz {
  id              String   @id @default(uuid())
  courseId        String
  lessonId        String
  title           String
  description     String?
  timeLimitMinutes Int
  passingScore    Int
  totalMarks      Int
  status          String
}

model QuizQuestion {
  id             String @id @default(uuid())
  quizId         String
  questionText   String
  questionType   String
  options        String // JSON string
  correctAnswer  String
  marks          Int
  explanation    String?
  order          Int
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  userId      String
  answers     String   // JSON string
  score       Int
  percentage  Decimal
  parsed      Boolean
  startedAt   DateTime @default(now())
  submittedAt DateTime
}

model Assignment {
  id              String   @id @default(uuid())
  courseId        String
  lessonId        String
  title           String
  description     String?
  dueDate         DateTime
  marks           Int
  allowedFileTypes String
  status          String
}

model AssignmentSubmission {
  id            String   @id @default(uuid())
  assignmentId  String
  userId        String
  fileUrl       String?
  textAnswer    String?
  submittedAt   DateTime @default(now())
  marksObtained Int?
  feedback      String?
  aiFeedback    String?
  status        String
}

// --- Community ---
model Discussion {
  id         String    @id @default(uuid())
  courseId   String
  userId     String
  title      String
  body       String
  tags       String?
  isResolved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  replies    DiscussionReply[]
}

model DiscussionReply {
  id             String     @id @default(uuid())
  discussionId   String
  discussion     Discussion @relation(fields: [discussionId], references: [id])
  userId         String
  body           String
  parentReplyId  String?
  createdAt      DateTime   @default(now())
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  userId    String
  rating    Int
  reviewText String?
  status    String
  createdAt DateTime @default(now())
}

model Certificate {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  certificateNumber String @unique
  certificateUrl  String
  issuedAt        DateTime @default(now())
  verificationCode String
}

// --- AI Engine ---
model AiTutorSession {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  lessonId      String
  title         String
  modelName     String
  createdAt     DateTime @default(now())
  lastMessageAt DateTime
  messages      AiChatMessage[]
}

model AiChatMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   AiTutorSession @relation(fields: [sessionId], references: [id])
  userId    String
  role      String
  message   String
  tokenUsed Int
  createdAt DateTime       @default(now())
}

model AiKnowledgeDocument {
  id         String @id @default(uuid())
  courseId   String
  lessonId   String
  title      String
  content    String
  fileUrl    String?
  sourceType String
  status     String
  createdAt  DateTime @default(now())
}

model AiEmbedding {
  id           String @id @default(uuid())
  documentId   String
  courseId     String
  chunkText    String
  embeddingVector String // Stores vector data
  metadata     String? // JSON string
  createdAt    DateTime @default(now())
}

model AiGeneratedContent {
  id        String   @id @default(uuid())
  courseId  String
  lessonId  String
  type      String
  prompt    String
  output    String
  reviewedByInstructor Boolean @default(false)
  createdAt DateTime @default(now())
}

model AiLearningRecommendation {
  id                String   @id @default(uuid())
  userId            String
  courseId          String
  weakTopics        String
  recommendedLessons String
  recommendedCourses String
  reason            String
  createdAt         DateTime @default(now())
}

model AiSettings {
  id          String  @id @default(uuid())
  provider    String
  modelName   String
  baseUrl     String
  maxTokens   Int
  temperature Decimal
  systemPrompt String
  isActive    Boolean @default(true)
}

// --- Communication ---
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  courseId  String
  createdBy String
  title     String
  message   String
  targetRole String
  createdAt DateTime @default(now())
}

// --- Payments & Settings ---
model Coupon {
  id               String   @id @default(uuid())
  code             String   @unique
  discountType     String
  discountTypeValue Decimal
  courseId         String
  maxUses          Int
  usedCount        Int      @default(0)
  startDate        DateTime
  endDate          DateTime
  status           String
  createdAt        DateTime @default(now())
}

model CouponUsage {
  id             String   @id @default(uuid())
  couponId       String
  userId         String
  orderId        String
  discountAmount Decimal
  usedAt         DateTime @default(now())
}

model PaymentMethod {
  id         String   @id @default(uuid())
  userId     String
  provider   String
  methodType String
  customerId String
  lastFour   String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Order {
  id             String   @id @default(uuid())
  orderNumber    String   @unique
  userId         String
  courseId       String
  
  // রিলেশন যোগ করুন (এটিই আপনাকে include ব্যবহার করতে সাহায্য করবে)
  course         Course   @relation(fields: [courseId], references: [id])
  
  amount         Decimal
  discountAmount Decimal
  taxAmount      Decimal
  totalAmount    Decimal
  currency       String
  status         String
  couponId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Payment {
  id                 String   @id @default(uuid())
  orderId            String
  userId             String
  courseId           String
  paymentMethodId    String
  provider           String
  providerTransactionId String
  amount             Decimal
  currency           String
  status             String
  gatewayResponse    String
  paidAt             DateTime?
  createdAt          DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  orderId       String
  userId        String
  courseId      String
  amount        Decimal
  discountAmount Decimal
  taxAmount     Decimal
  totalAmount   Decimal
  currency      String
  invoiceUrl    String
  issuedAt      DateTime @default(now())
}

// --- Logs & System ---
model LiveClass {
  id            String    @id @default(uuid())
  courseId      String
  instructorId  String
  title         String
  description   String?
  meetingUrl    String
  startTime     DateTime
  endTime       DateTime
  recordingUrl  String?
  status        String
}

model Attendance {
  id              String   @id @default(uuid())
  liveClassId     String
  userId          String
  joinedAt        DateTime
  leftAt          DateTime?
  durationMinutes Int
  status          String
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  ipAddress  String
  userAgent  String
  createdAt  DateTime @default(now())
}

model Setting {
  id              String  @id @default(uuid())
  siteName        String
  logo            String?
  defaultLanguage String
  allowRegistration Boolean
  certificateEnabled Boolean
  aiEnabled       Boolean
  maintenanceMode Boolean
}